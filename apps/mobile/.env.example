# ─── Auth (Clerk) ─────────────────────────────────────────────────────────────
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# ─── API ──────────────────────────────────────────────────────────────────────
# Dev: your local machine IP (not localhost — iOS simulator needs LAN IP)
# Production: https://api.yourdomain.com
EXPO_PUBLIC_API_URL=http://192.168.x.x:3100

# ─── Map ──────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_MAPBOX_TOKEN=pk.eyJ1Ijoi...
EXPO_PUBLIC_MAPBOX_STYLE=mapbox://styles/...

# ─── Analytics & Monitoring (optional — leave blank to disable) ───────────────
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_KEY=

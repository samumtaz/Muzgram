{
  "expo": {
    "name": "Muzgram",
    "slug": "muzgram",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "muzgram",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.muzgram.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Muzgram uses your location to show you halal restaurants, events, and businesses near you.",
        "NSLocationAlwaysUsageDescription": "Muzgram uses your location to show you nearby content.",
        "NSCameraUsageDescription": "Take photos to share with your community.",
        "NSPhotoLibraryUsageDescription": "Share photos from your library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0D0D0D"
      },
      "package": "com.muzgram.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Muzgram uses your location to show content near you."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#D4A853",
          "sounds": [
            "./assets/sounds/notification.wav"
          ]
        }
      ],
      "@rnmapbox/maps"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "clerkPublishableKey": "",
      "apiUrl": "",
      "mapboxAccessToken": "",
      "eas": {
        "projectId": "bfebf288-11da-4edd-b79b-43b2abe27ec7"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "samumtaz"
  }
}

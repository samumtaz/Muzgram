NODE_ENV=development
PORT=3100

# ─── Database (Supabase) ──────────────────────────────────────────────────────
# Pooled connection (used by the app at runtime via PgBouncer)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Direct connection (used by TypeORM migrations — bypasses PgBouncer)
DATABASE_DIRECT_URL=postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ─── Redis (Upstash or Railway) ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth (Clerk) ─────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# ─── Media (Cloudflare R2 / S3-compatible) ────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET=muzgram-media
R2_PUBLIC_URL=https://media.yourdomain.com

# ─── Push Notifications (Expo) ────────────────────────────────────────────────
EXPO_ACCESS_TOKEN=your_expo_access_token

# ─── Payments (Stripe) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ─── Maps / Geo ───────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_key

# ─── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=https://your@sentry.io/project

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_TOKEN=your-strong-admin-token

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:4000,https://admin.muzgram.com

# ─── Event Sync (Ticketmaster + Eventbrite) ───────────────────────────────────
# Ticketmaster: https://developer.ticketmaster.com — free, 5000 req/day
TICKETMASTER_API_KEY=your_ticketmaster_consumer_key
# Eventbrite: https://www.eventbrite.com/platform — free private token
EVENTBRITE_API_KEY=your_eventbrite_private_token

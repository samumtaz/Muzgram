{
  "name": "@muzgram/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "node --watch -r ts-node/register src/main.ts",
    "start": "node dist/main",
    "start:railway": "node -r ts-node/register/transpile-only -r tsconfig-paths/register src/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migrate": "ts-node -r tsconfig-paths/register src/database/run-migrations.ts run",
    "migrate:run": "ts-node -r tsconfig-paths/register src/database/run-migrations.ts run",
    "migrate:revert": "ts-node -r tsconfig-paths/register src/database/run-migrations.ts revert",
    "seed:chicago": "ts-node -r tsconfig-paths/register src/database/seeds/chicago-seed.ts",
    "seed:midwest": "ts-node -r tsconfig-paths/register src/database/seeds/midwest-seed.ts",
    "seed:posts": "ts-node -r tsconfig-paths/register src/database/seeds/posts-seed.ts",
    "seed:places": "ts-node -r tsconfig-paths/register src/database/seeds/google-places-scraper.ts",
    "seed:places:dry": "ts-node -r tsconfig-paths/register src/database/seeds/google-places-scraper.ts -- --dry-run",
    "enrich:photos": "ts-node -r tsconfig-paths/register src/database/seeds/enrich-photos.ts",
    "enrich:photos:dry": "ts-node -r tsconfig-paths/register src/database/seeds/enrich-photos.ts -- --dry-run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.705.0",
    "@aws-sdk/s3-request-presigner": "^3.705.0",
    "@clerk/backend": "^1.25.8",
    "@fastify/static": "^6.12.0",
    "@muzgram/constants": "workspace:*",
    "@muzgram/types": "workspace:*",
    "@muzgram/utils": "workspace:*",
    "@nestjs/bull": "^10.2.3",
    "@nestjs/cache-manager": "^2.3.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-fastify": "^10.4.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/typeorm": "^10.0.2",
    "@sentry/nestjs": "^8.0.0",
    "@sentry/node": "^8.0.0",
    "bull": "^4.16.3",
    "cache-manager": "^5.7.6",
    "cache-manager-redis-yet": "^5.1.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.4.2",
    "expo-server-sdk": "^3.11.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^17.7.0",
    "svix": "^1.40.0",
    "typeorm": "^0.3.20",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.2.0",
    "@nestjs/testing": "^10.4.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (Supabase) ──────────────────────────────────────────────────────
# Supabase Pooler — Transaction mode via PgBouncer (port 6543). Use this for the app.
# Found at: Supabase Dashboard → Settings → Database → Connection Pooling
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Supabase Direct — bypasses PgBouncer. Required for migrations and long-lived transactions.
# Found at: Supabase Dashboard → Settings → Database → Connection String (URI tab)
DATABASE_DIRECT_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ─── Redis ────────────────────────────────────────────────────────────────────
# Upstash Redis (REST API for cache)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here
# Upstash Redis (ioredis-compatible URL for Bull queues)
REDIS_URL=rediss://:your_password@your-redis.upstash.io:6380

# ─── Auth (Clerk) ─────────────────────────────────────────────────────────────
CLERK_PUBLISHABLE_KEY=<your_clerk_publishable_key>
CLERK_SECRET_KEY=<your_clerk_secret_key>
CLERK_WEBHOOK_SECRET=<your_clerk_webhook_secret>

# ─── Storage (Cloudflare R2) ──────────────────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=muzgram-media
R2_PUBLIC_URL=https://media.muzgram.com

# ─── Maps (Mapbox) ────────────────────────────────────────────────────────────
MAPBOX_ACCESS_TOKEN=pk.eyJ1IjoibXV6Z3JhbSIsImEiOiJjbHh4eHh4eHgifQ.xxxxxxxxxxxxxxxxxxxxxxxx
MAPBOX_STYLE_URL=mapbox://styles/muzgram/your_style_id

# ─── Push Notifications (Expo) ────────────────────────────────────────────────
EXPO_ACCESS_TOKEN=your_expo_access_token

# ─── Billing (Stripe) ────────────────────────────────────────────────────────
# Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=<your_stripe_secret_key>
STRIPE_PUBLISHABLE_KEY=<your_stripe_publishable_key>
# Stripe Dashboard → Developers → Webhooks → endpoint secret
STRIPE_WEBHOOK_SECRET=<your_stripe_webhook_secret>

# ─── AI Moderation (Google Vision) ───────────────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=muzgram-prod
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ─── Monitoring (OpenTelemetry → Grafana) ────────────────────────────────────
OTEL_SERVICE_NAME=muzgram-api
OTEL_EXPORTER_OTLP_ENDPOINT=https://tempo.grafana.net/otlp
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic base64encodedtoken

# ─── App Config ───────────────────────────────────────────────────────────────
APP_URL=https://muzgram.com
API_URL=https://api.muzgram.com
ADMIN_URL=https://admin.muzgram.com

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=120

# ─── Feed Config ──────────────────────────────────────────────────────────────
FEED_DEFAULT_RADIUS_KM=8
FEED_MAX_RADIUS_KM=40
FEED_PAGE_SIZE=20

# ─── Founding Member Config ───────────────────────────────────────────────────
FOUNDING_MEMBER_TOTAL_SLOTS=20
FOUNDING_MEMBER_PRICE_USD=149

# ─── Error Tracking (Sentry) ─────────────────────────────────────────────────
# API: Sentry DSN from Sentry Dashboard → Settings → Projects → muzgram-api
SENTRY_DSN=https://your_key@sentry.io/your_project_id

# ─── Product Analytics (PostHog) ─────────────────────────────────────────────
# PostHog Dashboard → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_key
# Mobile
EXPO_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_key
EXPO_PUBLIC_SENTRY_DSN=https://your_key@sentry.io/your_mobile_project_id

# ─── Web (SEO layer — apps/web) ───────────────────────────────────────────────
# Read-only Supabase direct connection (no pooler — RSCs hold connections)
DATABASE_READ_URL=postgresql://muzgram_web_readonly:password@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ISR webhook secret (shared with API CacheInvalidationService)
REVALIDATE_SECRET=your_revalidate_secret_here

# Cloudflare zone for Cache-Tag purging
CF_ZONE_ID=your_cloudflare_zone_id
CF_API_TOKEN=your_cloudflare_api_token_with_cache_purge_permission

# Public env vars (exposed to browser)
NEXT_PUBLIC_API_URL=https://api.muzgram.com
NEXT_PUBLIC_APP_SCHEME=muzgram
NEXT_PUBLIC_APP_STORE_ID=0000000000
